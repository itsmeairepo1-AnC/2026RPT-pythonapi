# SAP AI Core / Gen AI Hub credentials
# Copy to .env and fill in real values — never commit .env.

AICORE_AUTH_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com
AICORE_CLIENT_ID=<client-id-from-service-key>
AICORE_CLIENT_SECRET=<client-secret-from-service-key>
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=<your-resource-group>

# SAP-RPT-1 deployment base URL — /predict is appended automatically
RPT1_DEPLOYMENT_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com/v2/inference/deployments/<deployment-id>
